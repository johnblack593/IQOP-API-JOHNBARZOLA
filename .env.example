# ============================================================
# IQOP-API-JOHNBARZOLA — Variables de entorno
# Copiar este archivo a .env y completar los valores reales.
# NUNCA commitear el archivo .env con credenciales reales.
# ============================================================

# ── CREDENCIALES ─────────────────────────────────────────────
IQ_EMAIL=tu_email@ejemplo.com
IQ_PASSWORD=tu_password_seguro

# ── CUENTA ───────────────────────────────────────────────────
# Valores posibles: PRACTICE | REAL | TOURNAMENT
IQ_ACCOUNT_TYPE=PRACTICE

# ── CONEXIÓN (opcional — los defaults están en config.py) ────
# IQ_TIMEOUT_WS_CONNECT=15
# IQ_TIMEOUT_WS_DATA=30
# IQ_MAX_RECONNECT_ATTEMPTS=10

# ── RATE LIMITING (opcional) ─────────────────────────────────
# IQ_RATE_LIMIT_CAPACITY=5.0
# IQ_RATE_LIMIT_REFILL=0.5

# ── OBSERVABILIDAD (opcional) ────────────────────────────────
# IQ_LOG_LEVEL=INFO
# IQ_JOURNAL_PATH=.trades.jsonl

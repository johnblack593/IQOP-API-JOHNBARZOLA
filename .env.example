# .env.example — IQOP-API-JOHNBARZOLA
# Copiar a .env y completar con valores reales
# NUNCA commitear el .env real

# ── Credenciales ──────────────────────────────────────────────────────────────
IQ_EMAIL=tu@email.com
IQ_PASSWORD=tu_password_segura

# ── Cuenta ────────────────────────────────────────────────────────────────────
IQ_ACCOUNT_TYPE=PRACTICE                # PRACTICE | REAL

# ── Reconexión ────────────────────────────────────────────────────────────────
IQ_RECONNECT_MAX_ATTEMPTS=10
IQ_RECONNECT_BASE_DELAY=1.0             # segundos entre intentos

# ── Rate limiting ─────────────────────────────────────────────────────────────
IQ_ORDER_RATE_LIMIT=5                   # órdenes por segundo (no exceder)

# ── Buffers de memoria ────────────────────────────────────────────────────────
CANDLE_BUFFER_MAX=500                   # velas por activo por timeframe
CANDLE_TTL_SECONDS=86400                # 24h — velas más antiguas se descartan
TRADE_JOURNAL_MAX=1000                  # trades máx en memoria por sesión

# ── Timeouts de operaciones ───────────────────────────────────────────────────
CHECK_WIN_TIMEOUT=120.0                 # segundos máx esperando resultado de trade
STREAM_START_TIMEOUT=20.0              # segundos máx esperando inicio de stream
GET_POSITIONS_TIMEOUT=10.0             # segundos máx esperando portfolio snapshot

# ── Inteligencia de mercado ───────────────────────────────────────────────────
MARKET_QUALITY_MAX_SPREAD=0.001        # spread máximo aceptable para operar
MARKET_REGIME_ADX_PERIOD=14            # período para cálculo ADX
CORRELATION_THRESHOLD=0.8              # correlación máxima entre activos simultáneos
ASSET_SCANNER_MIN_PAYOUT=0.80          # payout mínimo aceptable (80%)

# ── IP Rotation (solo desarrollo Windows + WARP) ──────────────
# Activa la rotación de IP vía Cloudflare WARP cuando se
# detectan rate limits en auth.iqoption.com.
# NUNCA establecer en true en producción (servidor Linux).
# Requiere: Cloudflare WARP instalado en Windows.
ENABLE_IP_ROTATION=false
